   ],
   "source": [
    "with open('./names.txt') as file:\n",
    "    txt = file.readlines()\n",
    "    txt = list(map(lambda x: x.strip().capitalize(), txt))\n",
    "    txt = sorted(set(txt))\n",
    "    txt = (\"\\n\").join(txt)\n",
    "\n",
    "#  saving them in in new file\n",
    "with open('clean_names.txt',\"w\") as f:\n",
    "    f.write(txt)\n",
    "\n",
    "    print(txt,\"check\")"
   ]
  }
