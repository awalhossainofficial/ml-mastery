   "source": [
    "# rng = list(range(500))\n",
    "lst =[x for x in range(500)]\n",
    "def load_dataset(chunk,lst):\n",
    "    for i in range(0,len(lst), chunk):\n",
    "        print(f\"{i}\" \"chunk\",chunk,)\n",
    "        yield lst[i:chunk+i]\n",
    "\n",
    "x = load_dataset(5,lst)\n",
    "print(next(x))\n",
    "print(next(x))\n",
    "print(next(x))\n"
   ]
