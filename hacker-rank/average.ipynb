    "from functools import reduce\n",
    "\n",
    "\n",
    "inpt = int(input())\n",
    "arr = list(map(float, input().split()))\n",
    "\n",
    "\n",
    "x = reduce(lambda acc, x: acc+x, arr)\n",
    "print(f\"{x/inpt:.6f}\", \"checking\")\n",
    "\n"
   ]
  }
