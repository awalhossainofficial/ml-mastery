    "inpt = input().split()\n",
    "length_of_word = 0\n",
    "keywords = [\"ai\", \"data\", \"model\", \"learn\", \"train\", \"neural\"]\n",
    "\n",
    "for i in inpt:\n",
    "    if i.lower() in keywords:\n",
    "        length_of_word += 1\n",
    "\n",
    "if length_of_word > 2:\n",
    "    print(\"AI Detected\")\n",
    "else:\n",
    "    print(\"Not AI Related\")"
   ]
