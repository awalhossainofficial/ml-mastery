   "source": [
    "n = int(input())\n",
    "yes_count = 0\n",
    "no_count = 0\n",
    "\n",
    "for i in range(n):\n",
    "    vote = input()\n",
    "    if vote == \"YES\":\n",
    "        yes_count +=1\n",
    "    else:\n",
    "        no_count +=1\n",
    "\n",
    "if yes_count >= no_count:\n",
    "    print(\"ACCEPT\")\n",
    "else:\n",
    "    print(\"REJECT\")"
   ]
  }
 ],
