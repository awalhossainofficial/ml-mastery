    "import pandas as pd\n",
    "\n",
    "def dropDuplicateEmails(customers: pd.DataFrame) -> pd.DataFrame:\n",
    "    data = customers[customers.duplicated(\"email\", keep='first')]\n",
    "    customers.drop(data.index, axis=0, inplace=True)\n",
    "    print(data, \"checking\", data.index)\n",
    "    return customers\n",
    "\n"
   ]
