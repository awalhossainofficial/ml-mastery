    "import pandas as pd\n",
    "\n",
    "def pivotTable(weather: pd.DataFrame) -> pd.DataFrame:\n",
    "    new_d = weather.pivot_table(values=\"temperature\", index=\"month\",columns='city', aggfunc='sum')\n",
    "    return new_d"
