   "source": [
    "import pandas as pd\n",
    "\n",
    "def findHeavyAnimals(animals: pd.DataFrame) -> pd.DataFrame:\n",
    "    data = animals.loc[animals[\"weight\"] > 100].sort_values(\"weight\", ascending=False)[[\"name\"]]\n",
    "    return data"
   ]
