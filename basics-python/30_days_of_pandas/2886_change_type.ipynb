    "import numpy as np\n",
    "\n",
    "def changeDatatype(students: pd.DataFrame) -> pd.DataFrame:\n",
    "    new_data = np.array(students[\"grade\"],dtype=np.int16)\n",
    "    students[\"grade\"] = new_data\n",
    "    return students"
