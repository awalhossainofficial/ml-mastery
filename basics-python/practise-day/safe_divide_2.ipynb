   "source": [
    "def safe_divide(a,b):\n",
    "  try:\n",
    "    res = a / b\n",
    "    return res\n",
    "  except(ZeroDivisionError):\n",
    "    return(\"Division by zero\")\n",
    "  except (ValueError, TypeError):\n",
    "    return \"Please, provide valid inputs\"\n",
    "\n",
    "print(safe_divide(10, 5))  "
   ]
  }
