   "source": [
    "from functools import reduce\n",
    "inpt = int(input())\n",
    "arr = list(map(int, input().split()))\n",
    "\n",
    "min_val = reduce(lambda acc, x: acc if acc<x else x, arr)\n",
    "max_val = reduce(lambda acc, x: acc if acc>x else x, arr)\n",
    "\n",
    "print(min_val, max_val)\n"
   ]
  }
